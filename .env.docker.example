# cURLinator Docker Environment Configuration
# Copy this file to .env for docker-compose deployment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL credentials (used by both postgres and api services)
DATABASE_USER=curlinator
DATABASE_PASSWORD=curlinator_dev_password_change_in_production
DATABASE_NAME=curlinator_db
DATABASE_PORT=5432

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# IMPORTANT: Change this to a secure random string in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars
JWT_EXPIRATION_MINUTES=10080

# ============================================================================
# LLM PROVIDER CONFIGURATION (At least one required)
# ============================================================================

# OpenAI Configuration (Recommended)
OPENAI_API_KEY=sk-...

# Google Gemini Configuration
# GEMINI_API_KEY=...

# Anthropic Configuration
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# LLM MODEL CONFIGURATION
# ============================================================================

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ============================================================================
# EMBEDDING MODEL CONFIGURATION
# ============================================================================

# LOCAL: Uses BAAI/bge-small-en-v1.5 (free, runs locally)
EMBEDDING_PROVIDER=LOCAL

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================

# Port mapping for API service
API_PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# PGADMIN CONFIGURATION (Optional - only used with --profile tools)
# ============================================================================

PGADMIN_EMAIL=admin@curlinator.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================================================
# TESTING FLAG
# ============================================================================

# Set to false in production
TESTING=false

