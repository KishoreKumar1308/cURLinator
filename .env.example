# cURLinator Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION (Required)
# ============================================================================

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/curlinator_db

# Maximum number of database connection retry attempts (default: 5)
# Uses exponential backoff: 1s, 2s, 4s, 8s, 16s
# Important for Railway deployments where database may start after API
DATABASE_MAX_RETRIES=5


# ============================================================================
# JWT AUTHENTICATION (Required for Production)
# ============================================================================

# Secret key for JWT token signing
# IMPORTANT: Change this to a secure random string in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-this-in-production

# JWT token expiration time in minutes (default: 10080 = 7 days)
JWT_EXPIRATION_MINUTES=10080


# ============================================================================
# LLM PROVIDER CONFIGURATION (At least one required)
# ============================================================================

# OpenAI Configuration (Recommended)
OPENAI_API_KEY=sk-...

# Google Gemini Configuration
# GEMINI_API_KEY=...

# Anthropic Configuration
# ANTHROPIC_API_KEY=sk-ant-...


# ============================================================================
# LLM MODEL CONFIGURATION (Optional)
# ============================================================================

# LLM Provider: openai, anthropic, or gemini (default: openai)
LLM_PROVIDER=openai

# Model name (default: gpt-4o-mini for OpenAI)
LLM_MODEL=gpt-4o-mini

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0


# ============================================================================
# EMBEDDING MODEL CONFIGURATION (Optional)
# ============================================================================

# Default embedding provider: LOCAL, OPENAI, GEMINI, AUTO
# LOCAL: Uses BAAI/bge-small-en-v1.5 (free, runs locally)
EMBEDDING_PROVIDER=LOCAL


# ============================================================================
# CHROMA VECTOR DATABASE (Optional)
# ============================================================================

# Directory for Chroma persistent storage (default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db


# ============================================================================
# API SERVER CONFIGURATION (Optional)
# ============================================================================

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8000)
PORT=8000

# Environment: development, production (default: development)
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO


# ============================================================================
# CORS CONFIGURATION (Optional)
# ============================================================================

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ============================================================================
# ERROR TRACKING (Optional)
# ============================================================================

# Sentry DSN for error tracking and monitoring
# Get your DSN from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry integration
SENTRY_DSN=

# Sentry environment (default: same as ENVIRONMENT)
# SENTRY_ENVIRONMENT=production

# Sentry traces sample rate (0.0 to 1.0, default: 0.1 = 10% of requests)
# SENTRY_TRACES_SAMPLE_RATE=0.1


# ============================================================================
# USER API KEY ENCRYPTION (Required for BYOK)
# ============================================================================

# Encryption key for user-provided API keys (Fernet encryption)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Keep this secret and never commit it to version control!
API_KEY_ENCRYPTION_KEY=


# ============================================================================
# NOTES
# ============================================================================

# Required for production:
#   - DATABASE_URL
#   - JWT_SECRET (must be changed from default)
#   - At least one LLM API key

# Security:
#   - Never commit .env file to version control
#   - Always use strong, unique JWT_SECRET in production
#   - Rotate API keys regularly

